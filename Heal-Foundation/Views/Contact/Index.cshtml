@{
    ViewData["Title"] = "Contact Page";
}
<h1 class="text-center">Contact Us</h1>

<section class="w3l-contact-11">
    <div class="form-41-mian py-5">
        <div class="container py-lg-4">
            <div class="row align-form-map">
                <div class="col-lg-6 contact-left pr-lg-4">
                    <div class="partners">
                        <div class="cont-details">
                            <div class="title-content text-left"></div>
                            <p class="mt-3 mb-4 pr-lg-5">
                                Contact us using the provided contact details below
                            </p>
                        </div>
                        <h4>Heal Foundation</h4>
                        <div class="hours">
                            <h6 class="mt-4">Email:</h6>
                            <p>
                                <a href="mailto:HEALFOUNDATIONSA@GMAIL.COM">HEALFOUNDATIONSA@GMAIL.COM</a>
                            </p>
                            <h6 class="mt-4">Address:</h6>
                            <p>87 Harbottle road overport, KwaZulu Natal, South Africa</p>
                            <h6 class="mt-4">Contact: </h6>
                            <p class="margin-top">
                                <a href="tel:+(27) 607872575 ">0607872575 </a>
                            </p>
                            <h6 class="mt-4">Contact: Divesh</h6>
                            <p class="margin-top">
                                <a href="tel:+(27) 725321040">0725321040</a>
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 form-inner-cont">
                    <div class="title-content text-center">
                        <h3 class="hny-title mb-lg-5 mb-4">The Heal Team is excited to receive your feedback and connect with our valued supporters</h3>
                    </div>
                    <!-- Green Footer with Image -->
                    <footer class="custom-green-footer text-center">
                        <div>
                            <img src="~/images/Team.jpg" alt="Contact Us" class="img-fluid mb-4 hover-move" />
                        </div>
                    </footer>
                </div>
            </div>

            <div class="d-flex justify-content-center">
                <div class="map-container">
                    <div class="map-info text-center">
                        <h3>87 Harbottle road overport, KwaZulu Natal, South Africa</h3>
                        <p>Coordinates: -29.8291821, 31.0008731</p>
                        <p>Description: This is the location of Heal Foundation in Overport, Durban.</p>
                    </div>
                    <div class="map">
                        <!-- Map container -->
                        <div id="map" style="height: 500px; width: 100%;"></div>

                        <!-- Include Leaflet.js and Leaflet CSS -->
                        <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
                        <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

                        <script>
                            // Initialize the map, centered on Pietermaritzburg with zoom level 10
                            var map = L.map('map').setView([-29.6006, 30.3794], 10);

                            // Add OpenStreetMap tiles
                            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                                attribution: '&copy; OpenStreetMap contributors'
                            }).addTo(map);

                            // Define locations (latitude, longitude, name)
                            var locations = [
                                { lat: -29.6006, lng: 30.3794, name: "Pietermaritzburg" },
                                { lat: -29.5801, lng: 31.1186, name: "oThongathi (Tongaat)" },
                                { lat: -29.7067, lng: 31.0153, name: "Phoenix" },
                                { lat: -29.8838, lng: 30.9246, name: "Queensburgh" },
                                { lat: -29.9766, lng: 30.9294, name: "Isipingo" },
                                { lat: -30.0542, lng: 30.8904, name: "Amanzimtoti" }
                            ];

                            // Loop through locations and add markers
                            locations.forEach(function (location) {
                                L.marker([location.lat, location.lng]).addTo(map)
                                    .bindPopup(location.name) // Show location name in popup
                                    .openPopup();
                            });
                        </script>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Privacy Policy Footer -->
<footer class="text-center mt-5">
    <a href="/Home/Privacy" class="custom-green-link">Privacy Policy</a>
</footer>

<style>
    .custom-green-footer {
        background-color: #74A04E; /* Custom green color */
        padding: 40px 20px; /* Increased padding to make the footer larger */
        border-radius: 40px; /* Adds rounded corners to the footer */
        width: 90%; /* Adjusted width to make the footer larger */
        margin: 0 auto; /* Center align the footer */
    }

    .hover-move {
        transition: transform 0.3s ease-in-out;
    }

        .hover-move:hover {
            transform: scale(1.05); /* Slightly increases the size */
        }

    .custom-green-link {
        background-color: #74A04E; /* Custom green color */
        border-color: #74A04E; /* Custom green border color */
        color: white; /* Text color */
        padding: 0.375rem 0.75rem; /* Button padding */
        font-size: 1rem; /* Button font size */
        border-radius: 0.25rem; /* Button border radius */
        text-align: center; /* Center text */
        display: inline-block; /* Inline block display */
        text-decoration: none; /* Remove underline */
    }

        .custom-green-link:hover {
            background-color: #74A04E; /* Darker green on hover */
            border-color: #74A04E; /* Darker green border on hover */
            color: white; /* Ensure text color stays white */
        }
</style>
